# ============================================================
# ENVIRONMENT VARIABLES - Copy this file to .env.local
# and fill in the values for local development.
# For production, set these in the Vercel dashboard.
# ============================================================

# Company Information (displayed on the site)
NEXT_PUBLIC_COMPANY_NAME=
NEXT_PUBLIC_BRAND_TAGLINE=
NEXT_PUBLIC_LEGAL_NAME=
NEXT_PUBLIC_COMPANY_URL=
NEXT_PUBLIC_DOMAIN_NAME=
NEXT_PUBLIC_COPYRIGHT_YEAR=

# Contact Information (displayed on the site)
NEXT_PUBLIC_CONTACT_PHONE=
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_DIRECTOR_NAME=

# ============================================================
# EMAIL PROVIDER - Choose ONE: "smtp" or "resend"
# ============================================================
EMAIL_PROVIDER=smtp

# --- Option 1: SMTP (e.g., MXRoute, Gmail SMTP, any SMTP server) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Option 2: Resend API (https://resend.com - free: 100 emails/day) ---
# Sign up at resend.com, get API key from dashboard
RESEND_API_KEY=

# ============================================================
# EMAIL ROUTING - Where form submissions get sent
# ============================================================
# Sender address for all outgoing emails
FROM_EMAIL=
# Where contact form messages go
CONTACT_EMAIL=
# Where intake applications go (can be same as CONTACT_EMAIL)
INTAKE_EMAIL=

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=
NEXT_PUBLIC_SITE_URL=
